# ==============================
# APP CONFIG
# ==============================
NODE_ENV=development
PORT=8000
API_PREFIX=api

# ==============================
# FRONTEND
# ==============================
APP_ORIGINS=http://localhost:5173,https://example.com,https://www.example.com

# ==============================
# DATABASE (PostgreSQL)
# ==============================
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

# Crear tablas automáticamente
TYPEORM_SYNC=true

# ==============================
# JWT
# ==============================
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=jwt

# ==============================
# SEED
# ==============================
# Ejecuta seed al arrancar
RUN_SEED=true

# ==============================
# FILE STORAGE
# ==============================
UPLOAD_DIR=uploads

# ==============================
# VIDEO STREAMING
# ==============================
VIDEO_DIR=videos

# ==============================
# PLAYGROUND EXECUTION (Piston)
# ==============================
PISTON_URL=http://localhost:2000/api/v2/piston

# ==============================
# PLAYGROUND EXECUTION
# ==============================
PREFER_DIRECT_EXECUTION=true

# ==============================
# GOOGLE OAUTH
# ==============================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-api-domain.com/auth/google/callback
FRONTEND_URL=https://your-frontend-domain.com