{
  "info": {
    "name": "API de práctica — Exámenes Flutter",
    "description": "CRUD público (sin autenticación) usado por los alumnos en el examen de Flutter. Cada variante (ropa, libros, farmacia, tareas) tiene su propio endpoint y sus propios campos. Antes de usar, cambiá la variable `baseUrl` por la URL real del backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://tudominio.com/api", "type": "string" }
  ],
  "item": [
    {
      "name": "Ropa",
      "item": [
        {
          "name": "Listar prendas",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/practice-api/ropa/items", "host": ["{{baseUrl}}"], "path": ["practice-api", "ropa", "items"] }
          }
        },
        {
          "name": "Obtener prenda por id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/practice-api/ropa/items/:id", "host": ["{{baseUrl}}"], "path": ["practice-api", "ropa", "items", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Crear prenda",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prenda\": \"Camiseta oversize\",\n  \"talla\": \"L\",\n  \"color\": \"Negro\",\n  \"categoria\": \"Camisetas\",\n  \"precio\": 18.5,\n  \"stock\": 12,\n  \"disponible\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/practice-api/ropa/items", "host": ["{{baseUrl}}"], "path": ["practice-api", "ropa", "items"] }
          }
        },
        {
          "name": "Actualizar prenda",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"stock\": 5\n}" },
            "url": { "raw": "{{baseUrl}}/practice-api/ropa/items/:id", "host": ["{{baseUrl}}"], "path": ["practice-api", "ropa", "items", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Eliminar prenda",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/practice-api/ropa/items/:id", "host": ["{{baseUrl}}"], "path": ["practice-api", "ropa", "items", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Reiniciar datos demo",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/practice-api/ropa/items/reset", "host": ["{{baseUrl}}"], "path": ["practice-api", "ropa", "items", "reset"] }
          }
        }
      ]
    },
    {
